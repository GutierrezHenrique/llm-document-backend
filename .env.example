PORT=3001
OPENAI_API_KEY=sk-your-openai-api-key
DATABASE_URL="file:./prisma/dev.db"

# GCP Cloud Storage (opcional: se não definido, documentos são salvos em ./uploads)
# GCP_BUCKET_NAME=seu-bucket-rag
# Credenciais: use base64 do JSON da service account (recomendado em produção/CI)
# GOOGLE_APPLICATION_CREDENTIALS_BASE64=<base64 do conteúdo do key.json>
# Ou caminho para o arquivo (ex.: local):
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account-key.json
